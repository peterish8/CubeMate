# ─── Copy to .env.local and fill in your values ──────────────────────────────
#
# FRONTEND (set these in Vercel dashboard → Settings → Environment Variables)
# ─────────────────────────────────────────────────────────────────────────────

# Convex cloud sync (optional — enables dashboard + cross-device solve history)
# Run `npx convex dev` once locally — it writes this value to .env.local
VITE_CONVEX_URL=

# Signaling server URL (required for "Find Random Cuber" matchmaking)
# Development: http://localhost:3001
# Production:  https://cubemate-server.fly.dev  (your Fly.io app URL)
VITE_SIGNALING_URL=http://localhost:3001


# ─── SIGNALING SERVER (set these as Fly.io secrets, NOT in Vercel) ────────────
# Run: fly secrets set KEY=value
# ─────────────────────────────────────────────────────────────────────────────

PORT=3001

# Comma-separated list of allowed frontend origins
# Development: http://localhost:5173
# Production:  https://your-app.vercel.app,http://localhost:5173
# SIGNALING_CORS_ORIGINS=https://cubemate-liart.vercel.app,http://localhost:5173

# Matchmaking queue backend
# memory = in-process (queue lost on restart, fine for dev)
# redis  = Upstash Redis (persistent, required for production)
MATCHMAKING_BACKEND=memory
# MATCHMAKING_BACKEND=redis

# Upstash Redis credentials (only needed when MATCHMAKING_BACKEND=redis)
# Get these from: https://console.upstash.com → create Redis database → REST API
# UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your_token_here
