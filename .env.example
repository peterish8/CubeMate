# ─── After you have keys, copy to .env.local ───────────────────────────────────
#
# Convex: run `npx convex dev` once — it writes VITE_CONVEX_URL to .env.local
# VITE_CONVEX_URL=https://your-deployment.convex.cloud
#
# Upstash (production matchmaking): set on signaling server host, not Vite
# MATCHMAKING_BACKEND=redis
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

VITE_CONVEX_URL=

# Signaling / matchmaking (npm run server)
VITE_SIGNALING_URL=http://localhost:3001
PORT=3001
MATCHMAKING_BACKEND=memory
# MATCHMAKING_BACKEND=redis
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
# SIGNALING_CORS_ORIGINS=http://localhost:5173,https://your-app.vercel.app